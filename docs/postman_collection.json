{
  "info": {
    "_postman_id": "learningai-api-collection-v1",
    "name": "LearnAI API",
    "description": "Complete REST API collection for the LearnAI backend — 16 controllers, 63+ endpoints.\n\n**Quick Setup**\n1. Start the backend: `./gradlew bootRun`\n2. Run **POST Register** or **POST Login** in the Auth folder\n3. Tokens are auto-saved — all protected endpoints work immediately\n\n**Collection Variables**\n- `base_url` — API server (default `http://localhost:8080`)\n- `access_token` — JWT Bearer token (auto-set after login, expires in 24h)\n- `refresh_token` — Refresh token (auto-set after login, valid 7 days)\n\nAll protected endpoints inherit Bearer auth from the collection level.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "description": "LearnAI API base URL",
      "type": "default"
    },
    {
      "key": "access_token",
      "value": "",
      "description": "JWT access token — auto-set after login or register",
      "type": "secret"
    },
    {
      "key": "refresh_token",
      "value": "",
      "description": "JWT refresh token — auto-set after login or register",
      "type": "secret"
    }
  ],
  "item": [
    {
      "name": "🔓 Auth",
      "description": "Public authentication endpoints — no Bearer token required.",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resp = pm.response.json();",
                  "if (resp.success && resp.data) {",
                  "    pm.collectionVariables.set('access_token', resp.data.accessToken);",
                  "    pm.collectionVariables.set('refresh_token', resp.data.refreshToken);",
                  "    console.log('✅ Tokens stored! Access token expires in: ' + resp.data.accessTokenExpiresIn + 'ms');",
                  "} else {",
                  "    console.error('❌ Registration failed:', resp.message);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user account. Tokens are auto-saved to collection variables on success."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resp = pm.response.json();",
                  "if (resp.success && resp.data) {",
                  "    pm.collectionVariables.set('access_token', resp.data.accessToken);",
                  "    pm.collectionVariables.set('refresh_token', resp.data.refreshToken);",
                  "    console.log('✅ Logged in! Access token expires in: ' + resp.data.accessTokenExpiresIn + 'ms');",
                  "} else {",
                  "    console.error('❌ Login failed:', resp.message);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate with email and password. `access_token` and `refresh_token` are auto-saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resp = pm.response.json();",
                  "if (resp.success && resp.data) {",
                  "    pm.collectionVariables.set('access_token', resp.data.accessToken);",
                  "    pm.collectionVariables.set('refresh_token', resp.data.refreshToken);",
                  "    console.log('✅ Tokens refreshed!');",
                  "} else {",
                  "    console.error('❌ Refresh failed:', resp.message);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Use the refresh token to obtain a new access token. New tokens are auto-saved."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Logout the current user. Requires Bearer token. Invalidates the refresh token server-side."
          },
          "response": []
        }
      ]
    },
